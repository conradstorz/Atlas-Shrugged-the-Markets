*.db
*.sqlite
*.sqlite3
*.parquet
*.feather
*.h5
*.hdf5

# Runtime outputs and generated reports
.atlas/
reports/**
!reports/.gitkeep

# --- Logs / dumps ---
*.log
*.out
*.err
*.pid
*.stackdump
*.trace

